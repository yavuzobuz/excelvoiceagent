{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "description": "The URL of the user's profile photo."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user was created."
        }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "SavedItem": {
      "title": "SavedItem",
      "description": "A saved formula or macro generated by the AI.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who saved this item."
        },
        "type": {
          "type": "string",
          "enum": ["formula", "macro"],
          "description": "The type of the saved item."
        },
        "name": {
          "type": "string",
          "description": "The name of the formula or macro."
        },
        "code": {
          "type": "string",
          "description": "The actual formula or VBA code."
        },
        "explanation": {
          "type": "string",
          "description": "The explanation of what the code does."
        },
        "parameters": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" }
            }
          },
          "description": "The parameters of the formula or macro."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the item was saved."
        }
      },
      "required": ["userId", "type", "name", "code", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "/users/{userId}/saved_items/{itemId}": {
      "schema": {
        "$ref": "#/entities/SavedItem"
      },
      "description": "Stores formulas and macros saved by the user."
    }
  }
}
